<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="SIGEBI.Desktop.Presentacion.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGEBI - Panel de Administracion" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#083F75">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,24">
                    <Border Width="50" Height="50" CornerRadius="25" Background="#1061B0" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="S" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SIGEBI" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtRol" Text="Administrador" FontSize="11" Foreground="#23A2D9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Separator DockPanel.Dock="Top" Background="#1061B0" Margin="16,0,16,8"/>
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <Button Content="Recursos" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Recursos"/>
                    <Button Content="Prestamos" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Prestamos"/>
                    <Button Content="Penalizaciones" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Penalizaciones"/>
                    <Button Content="Usuarios" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Usuarios"/>
                    <Button x:Name="BtnAuditoria" Content="Auditoria" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Auditoria"/>
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Content="Cerrar Sesion" Style="{StaticResource SidebarButton}" Margin="8,0,8,16" Click="BtnCerrarSesion_Click"/>
            </DockPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <TextBlock x:Name="TxtPaginaActual" Text="Recursos" FontSize="18" FontWeight="SemiBold" Foreground="#083F75" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtUsuario" DockPanel.Dock="Right" FontSize="13" Foreground="#6C757D" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Background="#F0F2F5"/>
        </Grid>
    </Grid>
</Window>