<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="SIGEBI.Desktop.Presentacion.Views.Penalizaciones.PenalizacionesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Finalizar Penalizacion" Style="{StaticResource SuccessButton}" Click="BtnFinalizar_Click" Margin="0,0,8,0"/>
            <Button Content="Actualizar" Style="{StaticResource PrimaryButton}" Click="BtnActualizar_Click"/>
        </StackPanel>
        <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True" BorderBrush="#DEE2E6" BorderThickness="1">
            <DataGrid x:Name="DgPenalizaciones">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Usuario" Binding="{Binding IdUsuario}" Width="100"/>
                    <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="*"/>
                    <DataGridTextColumn Header="Monto" Binding="{Binding Monto}" Width="100"/>
                    <DataGridTextColumn Header="Fecha Inicio" Binding="{Binding FechaInicio}" Width="120"/>
                    <DataGridTextColumn Header="Activa" Binding="{Binding Activa}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>