<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="SIGEBI.Desktop.Presentacion.Views.Recursos.AgregarRevistaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Revista" Height="440" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Border Margin="24" Background="White" CornerRadius="8" Padding="24">
        <StackPanel>
            <TextBlock Text="Nueva Revista" FontSize="18" FontWeight="Bold" Foreground="#083F75" Margin="0,0,0,20"/>
            <TextBlock Text="Codigo" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtCodigo" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Titulo" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtTitulo" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Autor" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtAutor" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Numero de Edicion" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEdicion" Style="{StaticResource ModernTextBox}" Text="1" Margin="0,0,0,12"/>
            <TextBlock Text="Stock inicial" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtStock" Style="{StaticResource ModernTextBox}" Text="1" Margin="0,0,0,12"/>
            <TextBlock Text="ID Categoria" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtCategoria" Style="{StaticResource ModernTextBox}" Text="1" Margin="0,0,0,20"/>
            <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource DangerButton}" Click="BtnCancelar_Click" Margin="0,0,8,0"/>
                <Button Content="Guardar" Style="{StaticResource PrimaryButton}" Click="BtnGuardar_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>