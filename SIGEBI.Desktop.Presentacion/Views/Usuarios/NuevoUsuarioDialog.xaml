<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="SIGEBI.Desktop.Presentacion.Views.Usuarios.NuevoUsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo Usuario" Height="500" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Border Margin="24" Background="White" CornerRadius="8" Padding="24">
        <StackPanel>
            <TextBlock Text="Nuevo Usuario" FontSize="18" FontWeight="Bold" Foreground="#083F75" Margin="0,0,0,20"/>
            <TextBlock Text="Nombre" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNombre" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Apellido" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtApellido" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Contrasena" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12"/>
            <TextBlock Text="Rol" FontSize="12" FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbRol" Style="{StaticResource ModernComboBox}" Margin="0,0,0,20">
                <ComboBoxItem Content="Administrador" Tag="1"/>
                <ComboBoxItem Content="Bibliotecario" Tag="2"/>
                <ComboBoxItem Content="Estudiante" Tag="3" IsSelected="True"/>
            </ComboBox>
            <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource DangerButton}" Click="BtnCancelar_Click" Margin="0,0,8,0"/>
                <Button Content="Guardar" Style="{StaticResource PrimaryButton}" Click="BtnGuardar_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>